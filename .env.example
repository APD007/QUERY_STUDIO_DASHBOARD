# Port the combined frontend+API server listens on (Render sets this automatically).
PORT=5174

# Secret used to sign session JWTs. REQUIRED in production — if unset, a random
# secret is generated in memory on every process start, which invalidates every
# existing login session on each restart/redeploy. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# REQUIRED. Postgres connection string backing the app's own persistence (user
# accounts, saved queries/widgets/dashboards) — not used for the Data Sources
# tab, which connects to whatever DB the user points it at separately.
# Works with Render Postgres, Neon, Supabase, or any standard Postgres host:
#   postgres://user:password@host:5432/dbname
DATABASE_URL=

# Set to "disable" only for a local Postgres without SSL configured (e.g. a
# plain `docker run postgres` on localhost). Leave unset in production —
# hosted providers require SSL.
PGSSL=
